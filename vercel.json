{
  "crons": [{ "path": "/api/cron/materialize", "schedule": "0 6 * * *" }],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "liminalcalendar.com" }],
      "destination": "https://calendar.castalia.one/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.liminalcalendar.com" }],
      "destination": "https://calendar.castalia.one/:path*",
      "permanent": true
    }
  ]
}
