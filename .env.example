# Liminal Calendar Configuration
NODE_ENV=development
PORT=3004

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/liminal_calendar

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth (Hylo via auth.castalia.one gateway)
# AUTH_SECRET must match auth.castalia.one (castalia-one Vercel project)
AUTH_SECRET=your-auth-secret
HYLO_CLIENT_ID=castalia
HYLO_CLIENT_SECRET=your-hylo-client-secret

# Auth (Clerk — second provider beside Hylo, opens calendar to wider networks)
# Dev keys: dashboard.clerk.com → API keys
# Production: separate Clerk production instance required.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Google Calendar Integration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3004/auth/google/callback

# Authentication
JWT_SECRET=your-jwt-secret-min-32-chars
SESSION_SECRET=your-session-secret-min-32-chars

# Redis (for session storage)
REDIS_URL=redis://localhost:6379

# Email Reminders (choose one provider)
# Option 1: SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Option 2: Resend (recommended)
RESEND_API_KEY=re_...
EMAIL_FROM=calendar@liminalcommons.com

# Cron Job Security
CRON_SECRET=your-random-secret-for-cron-auth
